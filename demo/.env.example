# Database connection - copy to .env and set real values
DB_URL=jdbc:postgresql://localhost:5432/carservice
DB_USERNAME=postgres
DB_PASSWORD=your_password

# TLS (профиль tls) - путь к keystore и пароль
# SSL_KEY_STORE=file:./src/main/resources/certs/carservice-keystore.p12
# SSL_KEY_STORE_PASSWORD=changeit
