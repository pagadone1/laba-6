POST {{baseUrl}}/api/parts
Content-Type: application/json

{
  "name": "Фильтр воздушный",
  "price": 1200.00,
  "quantity": 15
}

### Create part 3
POST {{baseUrl}}/api/parts
Content-Type: application/json

{
  "name": "Тормозные колодки",
  "price": 4500.00,
  "quantity": 8
}

### Get all parts
GET {{baseUrl}}/api/parts

### Get part by id
GET {{baseUrl}}/api/parts/1

### Update part
PUT {{baseUrl}}/api/parts/1
Content-Type: application/json

{
  "name": "Масло моторное 5W-40 (премиум)",
  "price": 3800.00,
  "quantity": 25
