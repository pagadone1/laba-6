{
  "info": {
    "name": "Car Service PO4",
    "description": "Практическая работа 4: Spring Security, Basic Auth, регистрация",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "basic",
    "basic": [
      {"key": "username", "value": "{{username}}"},
      {"key": "password", "value": "{{password}}"}
    ]
  },
  "variable": [
    {"key": "baseUrl", "value": "http://localhost:8080"},
    {"key": "username", "value": "admin"},
    {"key": "password", "value": "SecurePass1!"},
    {"key": "customerId", "value": "1"},
    {"key": "vehicleId", "value": "1"},
    {"key": "mechanicId", "value": "1"},
    {"key": "orderId", "value": "1"}
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "1. Register (без авторизации)",
          "request": {
            "auth": {"type": "noauth"},
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"SecurePass1!\",\n  \"email\": \"admin@mail.ru\",\n  \"role\": \"ADMIN\"\n}"
            },
            "url": "{{baseUrl}}/api/register",
            "description": "Сначала выполни этот запрос — создаст пользователя. Пароль: 8+ символов, цифра, заглавная, строчная, спецсимвол."
          }
        }
      ]
    },
    {
      "name": "Customers",
      "item": [
        {"name": "Create customer", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"name\": \"Иван Петров\",\n  \"email\": \"ivan@mail.ru\",\n  \"phone\": \"+7-912-111-2233\"\n}"}, "url": "{{baseUrl}}/api/customers"}},
        {"name": "Get all customers", "request": {"method": "GET", "url": "{{baseUrl}}/api/customers"}},
        {"name": "Get customer by id", "request": {"method": "GET", "url": "{{baseUrl}}/api/customers/{{customerId}}"}},
        {"name": "Update customer", "request": {"method": "PUT", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"name\": \"Иван Петров (обновлён)\",\n  \"email\": \"ivan.updated@mail.ru\",\n  \"phone\": \"+7-912-111-2234\"\n}"}, "url": "{{baseUrl}}/api/customers/{{customerId}}"}},
        {"name": "Delete customer", "request": {"method": "DELETE", "url": "{{baseUrl}}/api/customers/{{customerId}}"}}
      ]
    },
    {
      "name": "Mechanics",
      "item": [
        {"name": "Create mechanic", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"name\": \"Сергей Мастеров\",\n  \"specialization\": \"Двигатель\"\n}"}, "url": "{{baseUrl}}/api/mechanics"}},
        {"name": "Get all mechanics", "request": {"method": "GET", "url": "{{baseUrl}}/api/mechanics"}},
        {"name": "Get mechanic by id", "request": {"method": "GET", "url": "{{baseUrl}}/api/mechanics/{{mechanicId}}"}},
        {"name": "Update mechanic", "request": {"method": "PUT", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"name\": \"Сергей Мастеров\",\n  \"specialization\": \"Двигатель и трансмиссия\"\n}"}, "url": "{{baseUrl}}/api/mechanics/{{mechanicId}}"}},
        {"name": "Delete mechanic", "request": {"method": "DELETE", "url": "{{baseUrl}}/api/mechanics/{{mechanicId}}"}}
      ]
    },
    {
      "name": "Parts",
      "item": [
        {"name": "Create part", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"name\": \"Масло моторное 5W-40\",\n  \"price\": 3500.00,\n  \"quantity\": 20\n}"}, "url": "{{baseUrl}}/api/parts"}},
        {"name": "Get all parts", "request": {"method": "GET", "url": "{{baseUrl}}/api/parts"}},
        {"name": "Get part by id", "request": {"method": "GET", "url": "{{baseUrl}}/api/parts/1"}},
        {"name": "Update part", "request": {"method": "PUT", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"name\": \"Масло моторное 5W-40 (премиум)\",\n  \"price\": 3800.00,\n  \"quantity\": 25\n}"}, "url": "{{baseUrl}}/api/parts/1"}},
        {"name": "Delete part", "request": {"method": "DELETE", "url": "{{baseUrl}}/api/parts/1"}}
      ]
    },
    {
      "name": "Vehicles",
      "item": [
        {"name": "Create vehicle", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"plateNumber\": \"А123БВ777\",\n  \"model\": \"Toyota Camry\",\n  \"year\": 2020,\n  \"ownerId\": 1\n}"}, "url": "{{baseUrl}}/api/vehicles"}},
        {"name": "Get all vehicles", "request": {"method": "GET", "url": "{{baseUrl}}/api/vehicles"}},
        {"name": "Get vehicle by id", "request": {"method": "GET", "url": "{{baseUrl}}/api/vehicles/{{vehicleId}}"}},
        {"name": "Get vehicles by owner", "request": {"method": "GET", "url": "{{baseUrl}}/api/vehicles/by-owner/{{customerId}}"}},
        {"name": "Update vehicle", "request": {"method": "PUT", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"plateNumber\": \"А123БВ777\",\n  \"model\": \"Toyota Camry\",\n  \"year\": 2021,\n  \"ownerId\": 1\n}"}, "url": "{{baseUrl}}/api/vehicles/{{vehicleId}}"}},
        {"name": "Delete vehicle", "request": {"method": "DELETE", "url": "{{baseUrl}}/api/vehicles/{{vehicleId}}"}}
      ]
    },
    {
      "name": "Service Orders",
      "item": [
        {"name": "Create order", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"vehicleId\": 1,\n  \"customerId\": 1,\n  \"mechanicId\": 1,\n  \"partIds\": [1, 2],\n  \"laborCost\": 5000.00,\n  \"requiredTasksCompleted\": false\n}"}, "url": "{{baseUrl}}/api/service-orders"}},
        {"name": "Get all orders", "request": {"method": "GET", "url": "{{baseUrl}}/api/service-orders"}},
        {"name": "Get order by id", "request": {"method": "GET", "url": "{{baseUrl}}/api/service-orders/{{orderId}}"}},
        {"name": "Update order", "request": {"method": "PUT", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"vehicleId\": 1,\n  \"customerId\": 1,\n  \"mechanicId\": 1,\n  \"partIds\": [1, 2],\n  \"laborCost\": 5500.00,\n  \"requiredTasksCompleted\": true\n}"}, "url": "{{baseUrl}}/api/service-orders/{{orderId}}"}},
        {"name": "Delete order", "request": {"method": "DELETE", "url": "{{baseUrl}}/api/service-orders/{{orderId}}"}}
      ]
    },
    {
      "name": "Business Operations",
      "item": [
        {"name": "Order total", "request": {"method": "GET", "url": "{{baseUrl}}/api/service-orders/{{orderId}}/total"}},
        {"name": "Add parts to order", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "[1, 3]"}, "url": "{{baseUrl}}/api/service-orders/{{orderId}}/parts"}},
        {"name": "Customer history", "request": {"method": "GET", "url": "{{baseUrl}}/api/service-orders/by-customer/{{customerId}}"}},
        {"name": "Mechanic open orders", "request": {"method": "GET", "url": "{{baseUrl}}/api/service-orders/by-mechanic/{{mechanicId}}/open"}},
        {"name": "Close order", "request": {"method": "PUT", "url": "{{baseUrl}}/api/service-orders/{{orderId}}/close"}}
      ]
    }
  ]
}
